digraph G {
    fontname="sans-serif";
    penwidth=1.5;
    
    // Title
    label="Telegram Sidecar Asynchronous HITL Flow";
    labelloc="t";
    fontsize=14;
    fontname="sans-serif-bold";
    
    // Global styles
    node [shape=box, style="rounded,filled", fontname="sans-serif", fontsize=11, fillcolor="#f5f5f5", color="#9e9e9e"];
    edge [fontname="sans-serif", fontsize=10];

    // Nodes
    Agent    [label="Subagent\n(blocked on task)", fillcolor="#ffebee", color="#e53935"];
    Reg      [label="Questions Registry\n📂 questions.json", shape=cylinder, fillcolor="#fff3e0", color="#fb8c00"];
    Sidecar  [label="Telegram Sidecar\nDaemon", fillcolor="#e1f5fe", color="#039be5"];
    User     [label="Human Operator\n(Telegram Mobile) 👨‍💻", shape=ellipse, fillcolor="#fff9c4", color="#fbc02d"];

    // Flow (U-shape)
    Agent -> Reg [dir=both, label="1. Writes question (pending)\n6. Polls & resumes (answered)", color="#e53935", penwidth=1.5];
    Reg -> Sidecar [dir=both, style=dashed, label="2. Polls pending\n5. Writes answer", color="#fb8c00", penwidth=1.5];
    Sidecar -> User [dir=both, label="3. Sends Telegram message\n4. Operator approves/rejects", color="#039be5", penwidth=1.5];

    // Layout constraints to force a compact 2x2 grid
    { rank=same; Agent; Reg; }
    { rank=same; User; Sidecar; }
}
